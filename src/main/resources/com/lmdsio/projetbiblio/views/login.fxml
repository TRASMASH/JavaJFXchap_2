<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="227.0" prefWidth="412.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lmdsio.projetbiblio.controllers.LoginController">
   <children>
      <VBox alignment="CENTER" layoutX="-5.0" prefHeight="400.0" prefWidth="600.0" AnchorPane.bottomAnchor="-5.0" AnchorPane.leftAnchor="-5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0">
         <children>
            <Label fx:id="loginText" alignment="CENTER" contentDisplay="CENTER" text="veuillez saisir vos identifiants ">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Label>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
               <children>
                  <Label text="login " />
                  <TextField fx:id="loginField" alignment="CENTER" />
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
               <children>
                  <Label alignment="CENTER" text="mot de passe" />
                  <PasswordField fx:id="passwordField" />
               </children>
            </HBox>
            <HBox alignment="TOP_RIGHT" prefHeight="100.0" prefWidth="200.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#onLoginClick" prefHeight="30.0" prefWidth="100.0" text="connexion " />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
